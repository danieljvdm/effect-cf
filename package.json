{
  "name": "effect-cf-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*/packages/*",
    "examples/*/workers/*",
    "examples/*/durable-objects/*",
    "examples/*/web",
    "tools/*"
  ],
  "type": "module",
  "scripts": {
    "postinstall": "bun scripts/postinstall.ts",
    "sync:effect": "bun scripts/sync-effect-submodule.ts",
    "patch:tsgo": "bun scripts/patch-tsgo.ts",
    "ready": "vp check && vp run -r test && vp run -r build",
    "changeset": "vp exec changeset",
    "changeset:version": "vp exec changeset version",
    "changeset:publish": "vp exec changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@cloudflare/vitest-pool-workers": "^0.16.3",
    "@effect/platform-bun": "catalog:",
    "@effect/tsgo": "0.5.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260423.1",
    "effect": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.20",
    "wrangler": "^4.93.1"
  },
  "overrides": {
    "@effect/platform-node-shared": "4.0.0-beta.70",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "bun@1.3.13",
  "catalog": {
    "@effect/platform-bun": "4.0.0-beta.70",
    "@effect/sql-d1": "4.0.0-beta.70",
    "@effect/sql-pg": "4.0.0-beta.70",
    "@effect/sql-sqlite-do": "4.0.0-beta.70",
    "@effect/vitest": "4.0.0-beta.70",
    "effect": "4.0.0-beta.70",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.20",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.20",
    "vite-plus": "0.1.20"
  }
}
